# -------------------------
# Meta / WhatsApp
# -------------------------
# Token que VOCÊ escolhe (qualquer string segura) — deve ser idêntico ao configurado no webhook da Meta
META_VERIFY_TOKEN=meu_token_unico_123

# Token de acesso gerado no painel Meta Developer (expira em 24h; veja SETUP_GUIDE.md para token permanente)
META_ACCESS_TOKEN=

# ID numérico do número de telefone de teste (ex: 1166755243178058)
META_PHONE_NUMBER_ID=

# Segredo do app — em Configurações do app > Básico no painel Meta Developer
META_APP_SECRET=

# -------------------------
# LLM
# -------------------------
# Escolha o provider: "openai" ou "deepseek"
LLM_PROVIDER=deepseek

# Chave DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# Chave OpenAI — necessária apenas se LLM_PROVIDER=openai
OPENAI_API_KEY=

# Modelo a usar (deixe em branco para usar o padrão do provider)
# deepseek: deepseek-chat | openai: gpt-4o-mini
LLM_MODEL=

# -------------------------
# Infraestrutura
# -------------------------
REDIS_URL=redis://redis:6379
DOCS_PATH=data/docs
CHROMA_PATH=data/chroma_db
